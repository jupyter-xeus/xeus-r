{
  "display_name": "R @R_VERSION_MAJOR@.@R_VERSION_MINOR@ (xr)",
  "argv": [
      "@XR_KERNELSPEC_PATH@xr",
      "-f",
      "{connection_file}"
  ],
  "language": "R",
  "metadata": {
    "debugger": false,
    "shared": {
      "libR.so": "lib/R/lib/libR.so",
      "libRblas.so": "lib/R/lib/libRblas.so",
      "libRlapack.so": "lib/R/lib/libRlapack.so",
      "libxeus.so": "lib/libxeus.so"
    }
  },
  "kernel_protocol_version": "5.6.0",
  "env": {
    "R_HOME": "@R_HOME@",
    "LD_LIBRARY_PATH": "@XEUS_R_LD_LIBRARY_PATH@"
  }
}
